{
  "name": "@bitgetbench/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "bitgetbench CLI: init, backtest, sim, submit, stats, verify",
  "license": "MIT",
  "bin": {
    "bitgetbench": "./dist/bin.js"
  },
  "exports": {
    ".": {
