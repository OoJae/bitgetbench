# BitgetBench environment. Copy to .env and fill in. Never commit .env.
#
# Public Bitget candle data needs NO auth, so the keys below are optional for v1.
# When set they must be READ-ONLY keys. BitgetBench never requests write/trade scopes.
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Bitget REST base (override only if the live docs change it). See packages/data.
BITGET_REST_BASE=https://api.bitget.com

# Database. Local dev defaults to SQLite (no setup). Postgres for the leaderboard.
# Examples:
#   DATABASE_URL=file:./bitgetbench.db
#   DATABASE_URL=postgres://user:pass@host:5432/bitgetbench
DATABASE_URL=file:./bitgetbench.db

# Live paper-sandbox alerts (Phase 3, optional).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
