# Copy to deploy/.env on the VPS (gitignored). provision.sh and the systemd service read it.

# nginx server_name for the leaderboard vhost. Use the VPS IP or a domain. Default: _
BENCH_SERVER_NAME=

# Public URL baked into the leaderboard at build (for the QR + share link). Optional.
NEXT_PUBLIC_SITE_URL=

# Shared SQLite database path (web service + write API + sandbox cron all point here).
BITGETBENCH_DB=/opt/bitgetbench/data-cache/bitgetbench.db

# Write API port (nginx routes /api/agents|backtest|jobs|verify here). Default 3940.
BENCH_API_PORT=3940

# Extra IPs the SSRF guard must never let a registered webhook reach. Put this host's own
# public IP here so a webhook cannot target the box itself. Comma-separated.
BITGETBENCH_BLOCK_IPS=

# Optional Telegram alerts on a failed sandbox cycle.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
