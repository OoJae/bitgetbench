# Copy to deploy/.env on the VPS (gitignored). provision.sh and the systemd service read it.

# nginx server_name for the leaderboard vhost. Use the VPS IP or a domain. Default: _
BENCH_SERVER_NAME=

# Public URL baked into the leaderboard at build (for the QR + share link). Optional.
NEXT_PUBLIC_SITE_URL=

# Shared SQLite database path (web service + sandbox cron point here).
BITGETBENCH_DB=/opt/bitgetbench/data-cache/bitgetbench.db

# Optional Telegram alerts on a failed sandbox cycle.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
